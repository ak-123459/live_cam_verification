UNKNOWN_CAPTURES_ROOT = "captures/unknown"  # unknown/{datetime_id}/face.jpg  + emb.npy
WATCHLIST_EVENTS_ROOT = "watchlist_events"

# Dedup – minimum cosine distance to consider two embeddings as "same shot"
# 0.15 means if new embedding is >85% similar to last saved → skip
EMBEDDING_DEDUP_DISTANCE = 0.15


# How many last embeddings to keep per identity for dedup check (RAM-light)
DEDUP_HISTORY_SIZE = "5"
API_HOST = "[::1]"
API_PORT = "8004"
API_TIMEOUT = "30"



