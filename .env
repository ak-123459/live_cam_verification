# ─────────────────────────────────────────────
# Constants – tweak here without touching logic
# ─────────────────────────────────────────────
KNOWN_CAPTURES_ROOT='captures/known'
UNKNOWN_CAPTURES_ROOT='captures/unknown'
WATCHLIST_EVENTS_ROOT='watchlist_events'

# Dedup – minimum cosine distance to consider two embeddings as "same shot"
# 0.15 means if new embedding is >85% similar to last saved → skip
EMBEDDING_DEDUP_DISTANCE='0.15'


# How many last embeddings to keep per identity for dedup check (RAM-light)
API_HOST='[::1]'
API_PORT='8004'
API_TIMEOUT='30'



# attendance watcher configurations
WATCH_DIR='./captures/unknown'
API_URL='http://[::1]:8004/attendance/batch'
CAMERA_ID='CAM_01'
INTERVAL='5'
MAX_BATCH='20'
EXTENSIONS  = {".jpg", ".jpeg", ".png"}
RESIZE_WIDTH='640'
MAX_FRAME_QUEUE='1'
PROCESS_N_FRAME='5'

# ── Face Recognition ──────────────────────────────────────────
ARC_FACE_MODEL='buffalo_s_int8'
FACE_THRESHOLD='0.2'
FRONT_FACE_THRESH='0.5'
MAX_FACES='20'
EMBEDDING_MIN_SIMILARITY='0.85'
UNKNOWN_COOLDOWN_SEC='10.0'

# ── Save / Storage ────────────────────────────────────────────
UNKNOWN_CAPTURES_ROOT='captures/unknown'
DEDUP_HISTORY_SIZE='10'
MAX_SAVE_QUEUE='20'
JPEG_QUALITY='0.9'


# ── PyAV Capture ──────────────────────────────────────────────
PYAV_THREAD_TYPE='slice'
PYAV_THREAD_COUNT='0'
PYAV_RTBUF='256k'
PYAV_PIXEL_FMT='bgr24'


# ── FFmpeg Low-Latency Options ────────────────────────────────
PYAV_ANALYZE_DURATION='100000'
PYAV_PROBE_SIZE='32768'
PYAV_FRAMEDROP=1

DET_SIZE='640,384'
DET_THRESH='0.3'
